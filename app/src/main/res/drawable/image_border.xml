<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fondo blanco para que se vea como borde -->
    <solid android:color="@android:color/white"/>

    <!-- Esquinas redondeadas -->
    <corners android:radius="12dp"/>

    <!-- Trazo blanco extra para reforzar el borde -->
    <stroke
        android:width="4dp"
        android:color="@android:color/white"/>

    <!-- Padding interior para que la imagen no cubra el borde -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp"/>
</shape>